{
  "name": "abxy/tripwire-server",
  "description": "Official Tripwire PHP server SDK",
  "type": "library",
  "license": "MIT",
  "version": "0.2.1",
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-sodium": "*",
    "ext-zlib": "*",
    "guzzlehttp/guzzle": "^7.9",
    "nyholm/psr7": "^1.8",
    "php-http/discovery": "^1.20",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^1.1 || ^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Tripwire\\Server\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tripwire\\Server\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --testsuite unit",
    "test:live": "vendor/bin/phpunit --testsuite live",
    "check:spec-sync": "bash ./scripts/check-spec-sync.sh",
    "check": [
      "composer validate",
      "@test"
    ]
  },
  "suggest": {
    "guzzlehttp/guzzle": "Provides the default PSR-18 HTTP client used for autodiscovery.",
    "nyholm/psr7": "Provides the default PSR-17 request and stream factories used for autodiscovery."
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "authors": [
    {
      "name": "ABXY Labs"
    }
  ],
  "homepage": "https://github.com/abxy-labs/tripwire-server-php",
  "support": {
    "issues": "https://github.com/abxy-labs/tripwire-server-php/issues",
    "source": "https://github.com/abxy-labs/tripwire-server-php"
  }
}
